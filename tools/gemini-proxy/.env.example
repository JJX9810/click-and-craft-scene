# NEXUS Gemini-Proxy – Beispielkonfiguration
# Diese Datei NACH "  .env  " kopieren und den echten Key eintragen.
# Die echte .env wird NICHT eingecheckt (siehe .gitignore).

GEMINI_API_KEY=your_gemini_api_key_here

# Optional:
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_PROXY_PORT=8787
# GEMINI_ALLOW_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:8765
